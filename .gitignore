# Backend ignores
backend/venv/
backend/random/
backend/__pycache__/
backend/.env

# Frontend ignores
frontend/node_modules/

# Global Model & Data ignores
/models/
/data/raw/
/data/processed/
*.xlsx

# Specific ignores for models
# We allow the smaller encoders but ignore the huge trend_classifier
backend/models/trend_classifier.pkl
# Optional: backend/models/model.pkl  # Keep if you want it on GitHub (71MB)

# Encoders (Keep these on GitHub)
!backend/models/city_encoder.pkl
!backend/models/crime_encoder.pkl
!backend/models/district_encoder.pkl
!backend/models/state_encoder.pkl

# Specific ignores for datasets (keeping backend/data)
/data/
!/backend/data/
!/backend/data/**/*.csv
!/backend/data/**/*.json

# JSON ignores
json/india.json
json/india_state.geojson
json/cleaned.geojson

# Misc
.DS_Store
Thumbs.db
.venv/
venv/